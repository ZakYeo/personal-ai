{
  "assistant": {
    "name": "Jarvis",
    "timeZone": "Europe/London",
    "wakePhrases": ["hey jarvis"]
  },
  "intent": {
    "provider": "openai",
    "openai": {
      "model": "gpt-5.4-nano"
    }
  },
  "conversation": {
    "provider": "openai",
    "history": {
      "maxTurnsBeforeCompaction": 5
    },
    "openai": {
      "model": "gpt-5.4-nano"
    }
  },
  "voice": {
    "input": "sox-rec",
    "streamingAudioInput": "sox-rec-stream",
    "streamingAudioOutput": "sox-play-stream",
    "streamingSpeechToText": "openai-realtime",
    "streamingTextToSpeech": "openai-streaming",
    "wakeActivation": "openwakeword-command",
    "wakeWord": "text-prefix",
    "speechToText": "command",
    "textToSpeech": "command",
    "audioOutput": "sox-play"
  },
  "desktopVoice": {
    "wakeActivation": {
      "command": "/opt/personal-ai/.venv/bin/python",
      "args": [
        "/opt/personal-ai/scripts/openwakeword-listener.py",
        "--model",
        "hey jarvis",
        "--threshold",
        "0.5"
      ],
      "timeoutMs": 86400000
    },
    "streamingAudioInput": {
      "command": "rec",
      "args": [
        "-q",
        "-r",
        "24000",
        "-c",
        "1",
        "-b",
        "16",
        "-e",
        "signed-integer",
        "-t",
        "raw",
        "-",
        "trim",
        "0",
        "8"
      ],
      "timeoutMs": 11000
    },
    "streamingAudioOutput": {
      "command": "play",
      "args": [
        "-q",
        "-t",
        "raw",
        "-r",
        "24000",
        "-e",
        "signed-integer",
        "-b",
        "16",
        "-c",
        "1",
        "-"
      ],
      "timeoutMs": 30000
    },
    "openAIRealtimeTranscription": {
      "model": "gpt-realtime-whisper"
    },
    "openAIStreamingSpeech": {
      "model": "gpt-4o-mini-tts",
      "voice": "coral",
      "instructions": "Speak clearly and concisely.",
      "responseFormat": "pcm",
      "timeoutMs": 30000
    },
    "wakeAudioInput": {
      "command": "rec",
      "args": [
        "-q",
        "-r",
        "16000",
        "-c",
        "1",
        "-b",
        "16",
        "{output}",
        "trim",
        "0",
        "4"
      ],
      "timeoutMs": 7000
    },
    "audioInput": {
      "command": "rec",
      "args": [
        "-q",
        "-r",
        "16000",
        "-c",
        "1",
        "-b",
        "16",
        "{output}",
        "trim",
        "0",
        "8"
      ],
      "timeoutMs": 11000
    },
    "speechToText": {
      "command": "/bin/sh",
      "environmentAllowlist": ["OPENAI_API_KEY"],
      "args": [
        "/opt/personal-ai/scripts/openai-audio-command.sh",
        "transcribe",
        "{input}"
      ],
      "timeoutMs": 30000
    },
    "textToSpeech": {
      "command": "/bin/sh",
      "environmentAllowlist": ["OPENAI_API_KEY"],
      "args": [
        "/opt/personal-ai/scripts/openai-audio-command.sh",
        "speak",
        "{output}"
      ],
      "stdin": "{text}",
      "timeoutMs": 30000
    },
    "audioOutput": {
      "command": "play",
      "args": ["-q", "{input}"],
      "timeoutMs": 10000
    }
  },
  "features": {
    "calendar": {
      "enabled": true,
      "adapter": "mock"
    },
    "messaging": {
      "enabled": true,
      "adapter": "mock"
    },
    "alarms": {
      "enabled": true,
      "adapter": "file",
      "state": {
        "path": "/var/lib/personal-ai/alarms.json"
      },
      "confirmationRequiredCapabilities": ["alarm.create"]
    }
  }
}
