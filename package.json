{
  "name": "personal-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first personal assistant built with a ports-and-adapters architecture.",
  "type": "module",
  "bin": {
    "personal-ai": "dist/runtimes/cli/main.js"
  },
  "files": [
    "config",
    "dist",
    "README.md"
  ],
  "scripts": {
    "architecture:check": "depcruise src --config .dependency-cruiser.cjs",
    "architecture:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot",
    "bin:check": "npm run build && node scripts/check-bin.mjs",
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run format:check && npm run package:sort:check && npm run docs:lint && npm run spellcheck && npm run secrets:check && npm run knip && npm run duplicates && npm run architecture:check && npm run bin:check && npm run test:run && npm run typecheck",
    "cli": "node --env-file-if-exists=.env --import tsx src/runtimes/cli/main.ts",
    "docs:lint": "markdownlint-cli2 \"**/*.md\"",
    "duplicates": "jscpd src test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "knip": "knip",
    "lint": "eslint .",
    "package:sort": "sort-package-json",
    "package:sort:check": "sort-package-json --check",
    "secrets:check": "secretlint \"**/*\"",
    "setup:openwakeword": "bash scripts/setup-openwakeword-venv.sh",
    "smoke:desktop-voice:openai": "PERSONAL_AI_RUN_DESKTOP_VOICE_OPENAI_SMOKE=1 node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs --run src/runtimes/desktop-voice-openai-smoke.e2e.test.ts",
    "smoke:pi:qemu": "tsx src/runtimes/pi/pi-qemu-smoke.ts",
    "spellcheck": "cspell .",
    "start": "npm run cli -- desktop-voice-service --config config/local-desktop-voice-openai.json",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:e2e:openai": "PERSONAL_AI_RUN_OPENAI_E2E=1 node --env-file=.env ./node_modules/vitest/vitest.mjs --run src/runtimes/openai-intent-routing.e2e.test.ts",
    "test:file": "vitest --run",
    "test:run": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,jsonc,md,yml,yaml,css,scss}": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "cspell": "^9.8.0",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "jscpd": "^5.0.11",
    "knip": "^5.41.1",
    "lint-staged": "^15.3.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.4.2",
    "secretlint": "^13.0.2",
    "sort-package-json": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
